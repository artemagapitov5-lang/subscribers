* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    font-size: xx-small;
    color: white;
}

body {
    min-height: 100vh;
    background: rgb(255, 255, 255);
}

.container {
    padding: 0;
    max-width: none;
    margin: 0; 
    width:100%;
}

.table-compact td, 
.table-compact th {
    padding: 3px 6px;
    line-height: 1.1;
}

.logo {
    position: absolute;
    top: 35px;
    left :40px;
    height: 50px;
}

.btn-success {
    background: transparent;
    color: #ff0000;                /* белый текст */
    border: none;               /* убираем рамку */
    border-radius: 8px;
    position: absolute;
    right: 60px;
    top: 70px;
    font-size: 14px;            /* размер шрифта */
    font-weight: bold;          /* жирный текст */
    cursor: pointer;            /* курсор-рука */
    transition: all 0.3s ease;  /* плавный ховер */
}

.btn-success:hover {
    background-color: #218838; /* чуть темнее при наведении */
    box-shadow: 0 6px 15px rgba(0,0,0,0.2); /* сильнее тень */
    transform: translateY(-2px); /* эффект "поднятия" */
}

.btn-success:active {
    transform: translateY(1px); /* при нажатии чуть опускается */
}

.btn-add {
    background: transparent;
    color: #000000;                /* белый текст */
    border: none;               /* убираем рамку */
    border-radius: 8px;
    position: absolute;
    right: 200px;
    top: 70px;
    font-size: 14px;            /* размер шрифта */
    font-weight: bold;          /* жирный текст */
    cursor: pointer;            /* курсор-рука */
    transition: all 0.3s ease;  /* плавный ховер */
}

.btn-add:hover {
    background-color: #218838; /* чуть темнее при наведении */
    box-shadow: 0 6px 15px rgba(0,0,0,0.2); /* сильнее тень */
    transform: translateY(-2px); /* эффект "поднятия" */
}



.btn-edit, .btn-delete, .btn-view {
    width: 32px;
    height: 32px;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    font-size: 0.9em;
    background: transparent;
}

.btn-edit {
    color: #5a5a5a;
    border: 1px solid #e0e0e0;
}

.btn-delete {
    color: #5a5a5a;
    border: 1px solid #e0e0e0;
}

.btn-view {
    color: #5a5a5a;
    border: 1px solid #e0e0e0;
}

.btn-edit:hover {
    background: linear-gradient(135deg, #4caf50, #2e7d32);
    color: white;
    border-color: #4caf50;
    transform: scale(1.1);
}
    
.btn-delete:hover {
    background: linear-gradient(135deg, #f44336, #d32f2f);
    color: white;
    border-color: #f44336;
    transform: scale(1.1);
}

.btn-view:hover {
    background: linear-gradient(135deg, #2196f3, #1976d2);
    color: white;
    border-color: #2196f3;
    transform: scale(1.1);
}


/* Стили для модального окна (ВЫНЕСЕНЫ ИЗ МЕДИА-ЗАПРОСА) */
.modal {
    display: none;
    position: fixed;
    z-index: 1000;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0,0,0,0.5);
}

.modal-content {
    background-color: white;
    margin: 10% auto;
    padding: 0;
    border-radius: 12px;
    width: 90%;
    max-width: 400px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.3);
    animation: modalSlideIn 0.3s ease;
}

@keyframes modalSlideIn {
    from { transform: translateY(-50px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
}

.modal-header {
    background: linear-gradient(135deg, #e8f5e9, #c8e6c9);
    padding: 15px 20px;
    border-radius: 12px 12px 0 0;
    border-bottom: 2px solid #4caf50;
    display: flex;
    justify-content: flex-end;
}

.modal-body {
    padding: 20px;
    max-height: 60vh;
    overflow-y: auto;
}

.modal-form-group {
    margin-bottom: 15px;
}

.modal-form-group label {
    display: block;
    margin-bottom: 5px;
    font-weight: 600;
    color: #2c3e50;
    font-size: 0.9em;
}

.modal-form-group input {
    width: 100%;
    padding: 8px 12px;
    border: 2px solid #e0e0e0;
    border-radius: 6px;
    font-size: 14px;
    transition: all 0.3s ease;
    color: black;
}

.modal-form-group input:focus {
    outline: none;
    border-color: #00cc66;
    box-shadow: 0 0 0 3px rgba(0, 204, 102, 0.2);
}

.modal-footer {
    padding: 15px 20px;
    background: #f8f9fa;
    border-radius: 0 0 12px 12px;
    border-top: 1px solid #e0e0e0;
    display: flex;
    justify-content: flex-end;
    gap: 10px;
}

.btn-cancel {
    padding: 8px 16px;
    background: #6c757d;
    color: white;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.3s ease;
    font-size: 0.9em;
}

.btn-cancel:hover {
    background: #5a6268;
}

.btn-save {
    padding: 8px 16px;
    background: linear-gradient(135deg, #00cc66, #009944);
    color: white;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.3s ease;
    font-size: 0.9em;
}

.btn-cancel-edit{
    padding: 8px 16px;
    background: #6c757d;
    color: white;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.3s ease;
    font-size: 0.9em;
}

.btn-update {
   padding: 8px 16px;
   background: linear-gradient(135deg, #00cc66, #009944);
   color: white;
   border:none;
   border-radius: 6px;
   cursor: pointer;
   transition: all 0.3s ease;
   font-size: 0.9em;
}
.btn-cancel-edit:hover {
   background: #5a6268;
}

.btn-update:hover {
    background: linear-gradient(135deg, #009944, #007a33);
}
.btn-save:hover {
    background: linear-gradient(135deg, #009944, #007a33);
}

.close {
    font-size: 1.5em;
    cursor: pointer;
    color: #666;
    transition: color 0.3s ease;
    line-height: 1;
}

.close:hover {
    color: #333;
}

@media (max-width: 768px) {
    .container {
        padding: 16px;
    }
    
    .btn-edit, .btn-delete, .btn-view {
        width: 28px;
        height: 28px;
    }
    
    .user-info strong,
    .user-login {
        max-width: 120px;
    }
    
    .modern-table td {
        max-width: 150px;
    }
    
    /* Адаптивные стили для модального окна на мобильных */
    .modal-content {
        margin: 5% auto;
        width: 95%;
        max-width: 350px;
    }
    
    .modal-body {
        padding: 15px;
    }
   
    .modal-header {
        padding: 12px 15px;
    }
    
    .modal-footer {
        padding: 12px 15px;
        flex-direction: column;
    }
    
    .btn-cancel, .btn-save {
        width: 100%;
    }
    .modal-form-group select {
    width: 100%;
    padding: 8px 12px;
    border: 2px solid #e0e0e0;
    border-radius: 6px;
    font-size: 14px;
    transition: all 0.3s ease;
    background: white;
}

.modal-form-group select:focus {
    outline: none;
    border-color: #00cc66;
    box-shadow: 0 0 0 3px rgba(0, 204, 102, 0.2);
}